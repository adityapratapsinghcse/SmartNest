// Copy this file to secrets.h (same folder) and fill in your real values.
// secrets.h is gitignored on purpose - never commit real WiFi passwords or device keys.

#define WIFI_SSID "your-wifi-name"
#define WIFI_PASSWORD "your-wifi-password"

// Your deployed backend's base URL, no trailing slash
#define API_BASE_URL "https://your-backend.up.railway.app"

// From Django admin -> Devices -> Devices -> your device -> device_key
#define DEVICE_KEY "your-device-key"
